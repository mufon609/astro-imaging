requires 1.4.0
set16bits
cd @SET@
convert light -out=../work
cd ../work
# @CALIBRATE@ is the shared light-calibration command from
# scripts/stack/calibrate_light.sh (calibrate_light_cmd): dark subtraction +
# mandatory -cc=dark cosmetic hot/cold-pixel correction + the flat/CFA/debayer
# flags run_pipeline.sh resolves for this set (flat + equalize_cfa when flats
# match the set's focal/aperture, no flat when they don't). On a low-dark-
# current sensor the master dark is ~0, so its hot-pixel map for -cc=dark is
# the win; -opt is never needed.
@CALIBRATE@
# Two-pass: measure all frames first, pick the reference that maximizes
# registrable overlap — the fixed-tripod field drift otherwise strands the
# late frames too far from a sequence-start reference (6/32 dropped in 1-pass).
# Lower detection threshold: default sigma 1.0 finds ~370 stars/frame and the
# matcher still fails on 2 frames; fainter stars give it more triangles.
setfindstar -sigma=0.5
register pp_light -2pass
seqapplyreg pp_light
set32bits
# Color is calibrated by SPCC on the stack — no per-channel white balance
# at stack time (-rgb_equal): a stack-time rescale would only obscure the
# raw channel balance SPCC measures.
stack r_pp_light @REJ@ @STACKPOL@-norm=addscale -output_norm -out=@RESULTS@/stack_@SET@
close
