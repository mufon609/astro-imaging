requires 1.4.0
set16bits
cd work
# Second self-flat median: the radial shape of the ACTUAL frames the
# pipeline divides (glow-subtracted + rechroma'd), so the division is flat
# by construction. nonorm: rechroma already aligned the levels; norm=mul
# would rescale per frame and distort the shared shape.
set32bits
stack bkg_pp_light med -nonorm -out=selfflat_med2
set16bits
close
