requires 1.4.0
set16bits
cd @SET@
convert light -out=../work
cd ../work
# No matching flat exists for this set (preflight decides): calibrate without
# flat, then build a SELF-FLAT from the frames themselves.
calibrate light -dark=masters/dark_master -cc=dark 3 3 -cfa -debayer
# V is ESTIMATED from the untouched median: per-pixel median of the
# UNREGISTERED calibrated frames — drifting stars reject (fixed tripod),
# the static vignette x sky survives, and the multiplicative factorization
# V x S holds. Estimating it from the glow-subtracted frames instead makes
# the extracted V diverge per channel (subsky's per-channel level
# restoration shifts the pedestal/bowl ratio) and tints the corners on
# division.
set32bits
stack pp_light med -norm=mul -out=selfflat_med
set16bits
# The frames that continue through the pipeline DO get their PLANAR glow
# subtracted first (level-preserving, sensor coords, while linear).
# Degree stays 1: a higher degree flattens the rim curvature but ALSO
# erases the Milky Way from the stack — at wide focals the MW band is
# frame-scale curvature, indistinguishable from glow curvature by any
# unmasked smooth fit (measured: seqsubsky 2 took the MW +38 -> +0.0).
seqsubsky pp_light 1
close
