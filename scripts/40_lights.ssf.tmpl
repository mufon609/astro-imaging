requires 1.4.0
set16bits
cd @SET@
convert light -out=../work
cd ../work
# Dark: full subtraction when exposure-matched, bias+hot-pixel map otherwise
# (preflight warns) — Z6III mean dark current is ~0 either way; the hot-pixel
# map for -cc=dark is the win. -opt never needed. @FLATOPT@ is set by
# run_pipeline.sh preflight: flat + equalize_cfa when flats match the set's
# focal/aperture, empty (no flat) when they don't.
calibrate light -dark=masters/dark_master @FLATOPT@ -cc=dark 3 3 -cfa -debayer
# Two-pass: measure all frames first, pick the reference that maximizes
# registrable overlap — the fixed-tripod field drift otherwise strands the
# late frames too far from a sequence-start reference (6/32 dropped in 1-pass).
# Lower detection threshold: default sigma 1.0 finds ~370 stars/frame and the
# matcher still fails on 2 frames; fainter stars give it more triangles.
setfindstar -sigma=0.5
register pp_light -2pass
seqapplyreg pp_light
set32bits
# -rgb_equal: stack-time white balance. INERT once SPCC runs on the stack
# (linear scalings compose; SPCC's fit absorbs it) — removal queued, needs
# catalog re-download + re-stack + re-SPCC + gate verify (NOTES ledger).
stack r_pp_light rej 3 3 -norm=addscale -output_norm -rgb_equal -out=../results/stack_@SET@
close
