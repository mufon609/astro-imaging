requires 1.4.0
set16bits
cd work
# Divide every calibrated frame by the fitted gain surface: a second calibrate
# pass with only -flat. The gain is normalized to mean 1.0 (levels preserved);
# division is the correct (multiplicative) vignette removal, so corner stars
# and sky get re-brightened together — subsky alone cannot do that.
calibrate pp_light -flat=selfflat_gain
setfindstar -sigma=0.5
register pp_pp_light -2pass
seqapplyreg pp_pp_light
set32bits
stack r_pp_pp_light rej 3 3 -norm=addscale -output_norm -rgb_equal -out=../results/stack_@SET@
close
