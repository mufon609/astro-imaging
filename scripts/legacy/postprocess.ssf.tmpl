# LEGACY QUICK-LOOK (single-stretch, no star separation) driven by
# run_post.sh — for fast pipeline-stage inspection and the historical QA
# anchors. THE PRODUCT CHAIN IS scripts/render/starcomb.py (approved recipe B7);
# do not tune final aesthetics here.
requires 1.4.0
cd results
load stack_@SET@
# Stats first, on the linear stack: record Median + bgnoise per channel before
# and after any pipeline change; compare noise/median (level-independent —
# output normalization rescales the stack when the reference frame changes).
stat
bgnoise
# Background extraction while linear. @SUBSKY@ comes from run_pipeline/run_post:
# flat-matched (landscape) sets get polynomial degree 1 (RBF carves around
# treelines); self-flat pure-sky sets get RBF with dense samples, raised
# tolerance and low smoothing — tolerance must be high enough to SAMPLE the
# horizon glow (default rejects it as "not background" and it survives), and
# low smoothing follows cloud-scale color structure.
subsky @SUBSKY@ -dither
# Per-op intermediates for the stage inspection report (run_post.sh measures
# then deletes them).
save ../work/post_subsky
# NL-Bayes with variance stabilization: ~-40% background grain, faint stars
# survive. Costs ~3 min/run — comment out when iterating on gradients only.
denoise -vst
save ../work/post_denoise
# LINKED stretch to a dark 0.12 background (the linear stack is neutral, so
# a linked stretch keeps it that way; unlinked hides casts but distorts
# channel shapes). No satu / no rmgreen — both measured as the source of the
# "dyed red" look (satu amplifies warm signal regions; SCNR clamps G on a
# sky that is not green-dominant and shifts everything magenta).
autostretch -linked -2.0 0.12
save ../work/post_stretch
# Trim the RBF extrapolation zone + thin stacking coverage at the edges.
crop @CROPX@ @CROPY@ @CROPW@ @CROPH@
savejpg preview_@SET@ 92
close
